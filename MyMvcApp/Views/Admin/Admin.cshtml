@model IEnumerable<MyMvcApp.Models.AppUser>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    body { background-color: #14110F; color: #D9C5B2; }
    .table { color: #D9C5B2; margin-top: 1rem; }
    .table th { border-bottom: 2px solid #7E7F83; }
    .table td { border-bottom: 1px solid #34312D; vertical-align: middle; }
    .btn-approve { background-color: #28a745; color: white; border: none; padding: 5px 15px; border-radius: 4px; }
    .btn-disable { background-color: #dc3545; color: white; border: none; padding: 5px 15px; border-radius: 4px; }
    .btn-role { background-color: #D9C5B2; color: #14110F; border: none; padding: 5px 15px; border-radius: 4px; }
</style>

<div class="container mt-5">
    <h2>System Administrator Workspace</h2>
    <p class="text-muted">Manage user approvals and role assignments below.</p>

    <form asp-action="Admin" method="get" class="mb-4 d-flex">
        <input type="text" name="searchEmail" class="form-control me-2" placeholder="Search by Email..." style="max-width: 300px; background-color: #34312D; color: #D9C5B2; border: 1px solid #7E7F83;" value="@Context.Request.Query["searchEmail"]" />
        <button type="submit" class="btn btn-primary" style="background-color: #D9C5B2; color: #14110F; border: none;">Search</button>
        <a asp-action="Admin" class="btn btn-secondary ms-2">Clear</a>
    </form>

    <table class="table">
        <thead>
            <tr>
                <th>Email</th>
                <th>Status</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>
                        @if (user.IsDisabled) { <span class="badge bg-danger">Disabled</span> }
                        else if (!user.IsApproved) { <span class="badge bg-warning text-dark">Pending</span> }
                        else { <span class="badge bg-success">Approved</span> }
                    </td>
                    <td>
                        <form asp-action="ChangeRole" method="post" class="d-inline-flex">
                            <input type="hidden" name="id" value="@user.Id" />
                            <select name="newRole" class="form-select form-select-sm bg-dark text-light border-secondary" style="width: 120px; margin-right: 10px;" @(user.IsDisabled ? "disabled" : "")>
                                <option value="Tenant" selected="@(user.Role == "Tenant")">Tenant</option>
                                <option value="Landlord" selected="@(user.Role == "Landlord")">Landlord</option>
                                <option value="Admin" selected="@(user.Role == "Admin")">Admin</option>
                            </select>
                            <button type="submit" class="btn-role btn-sm" @(user.IsDisabled ? "disabled" : "")>Save</button>
                        </form>
                    </td>
                    <td>
                        @if (user.IsDisabled)
                        {
                            <form asp-action="EnableUser" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('Are you sure you want to enable this user?');">Enable</button>
                            </form>
                        }
                        else
                        {
                            @if (!user.IsApproved)
                            {
                                <form asp-action="ApproveUser" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn-approve btn-sm me-2">Approve & Email</button>
                                </form>
                            }
                            
                            <form asp-action="DisableUser" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to disable this user?');">Disable</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>