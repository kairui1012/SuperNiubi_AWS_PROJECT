@model MyMvcApp.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<style>
    body { background-color: #14110F; color: #D9C5B2; }
    .auth-container { display: flex; justify-content: center; align-items: center; min-height: 80vh; }
    .auth-card { background-color: #34312D; padding: 2.5rem; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.3); width: 100%; max-width: 400px; }
    .form-control { background-color: #14110F; border: 1px solid #7E7F83; color: #D9C5B2; border-radius: 6px; }
    .form-control:focus { background-color: #14110F; color: #D9C5B2; border-color: #D9C5B2; box-shadow: none; }
    .btn-primary { background-color: #D9C5B2; color: #14110F; border: none; font-weight: 600; width: 100%; padding: 0.6rem; border-radius: 6px; transition: all 0.2s; }
    .btn-primary:hover { background-color: #7E7F83; color: #14110F; }
    .text-danger { color: #ff6b6b !important; }
    .text-muted a { color: #7E7F83; text-decoration: none; transition: color 0.2s; }
    .text-muted a:hover { color: #D9C5B2; }
</style>

<div class="auth-container">
    <div class="auth-card">
        <h2 class="text-center mb-4">Create Account</h2>
        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            

            <div class="form-group mb-3">
                <label asp-for="Email" class="mb-1"></label>
                <input asp-for="Email" class="form-control" placeholder="Enter email address" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-4">
                <label asp-for="Password" class="mb-1"></label>
                <input asp-for="Password" class="form-control" placeholder="Create a password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            
            <button type="submit" class="btn btn-primary">Sign Up</button>

            <div class="text-center mt-4 text-muted">
                Already have an account? <a asp-action="Login">Log In</a>
            </div>
        </form>
    </div>
</div>